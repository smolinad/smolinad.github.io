---
interface Props {
    institution: string;
    position: string;
}

const {institution, position} = Astro.props;
---

<li class="mb-10 ms-4">
    <div class="absolute w-2 h-2 bg-gray-200 rounded-full mt-2 -start-1 dark:bg-gray-700"></div>
    <time class="mb-1 text-sm font-normal leading-none text-gray-200 dark:text-gray-200">February 2022</time>
    <h3 class="text-lg font-normal text-green-200 opacity-70 dark:text-white">{institution} — {position}</h3>
    <div class="mb-4 text-base font-normal text-white opacity-70 dark:text-gray-400">
        <slot />
    </div>
</li>